# ============================================================
# Autonomous AI SRE Platform — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# ==================== DATABASE ====================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sre_platform
POSTGRES_USER=sre_admin
POSTGRES_PASSWORD=sre_secret_2024

# ==================== REDIS ====================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================== KAFKA ====================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ==================== AI / LLM ====================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=2000

# ==================== SECURITY ====================
JWT_SECRET=your-256-bit-secret-key-for-jwt-signing-change-this-in-production-immediately
JWT_EXPIRATION_MS=3600000

# ==================== NOTIFICATIONS ====================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
PAGERDUTY_ROUTING_KEY=your-pagerduty-routing-key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ==================== OBSERVABILITY ====================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PROMETHEUS_URL=http://localhost:9090
JAEGER_URL=http://localhost:16686

# ==================== GRAFANA ====================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ==================== SERVICE PORTS ====================
API_GATEWAY_PORT=8080
LOG_INGESTION_PORT=8081
INCIDENT_SERVICE_PORT=8082
AI_ENGINE_PORT=8083
HEALING_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085
FRONTEND_PORT=3001
